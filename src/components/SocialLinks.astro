---
interface Props {
  tone?: "light" | "dark";
  showLabels?: boolean;
}

const { tone = "light", showLabels = false } = Astro.props;
const links = [
  ["LinkedIn", "https://www.linkedin.com/company/computerformsmx", "M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-4 0v7h-4V9h4v2a4 4 0 0 1 2-3z M2 9h4v12H2z M4 3a2 2 0 1 1 0 4 2 2 0 0 1 0-4z"],
  ["Instagram", "https://www.instagram.com/computerformsmx/", "M7 2h10a5 5 0 0 1 5 5v10a5 5 0 0 1-5 5H7a5 5 0 0 1-5-5V7a5 5 0 0 1 5-5z M8 12a4 4 0 1 0 8 0 4 4 0 0 0-8 0z M17.5 6.5h.01"],
  ["Facebook", "https://www.facebook.com/computerformsmx/", "M14 8h3V4h-3a5 5 0 0 0-5 5v3H6v4h3v6h4v-6h3l1-4h-4V9a1 1 0 0 1 1-1z"],
];

const base = tone === "dark"
  ? "border-white/18 bg-white/8 text-white/88 hover:border-cf-yellow hover:text-cf-yellow"
  : "border-cf-navy/12 bg-white text-cf-navy hover:border-cf-red hover:text-cf-red";
---

<div class="flex flex-wrap gap-2" aria-label="Redes sociales">
  {links.map(([label, href, path]) => (
    <a href={href} target="_blank" rel="noreferrer" aria-label={label} class:list={["inline-flex h-10 items-center justify-center gap-2 rounded-full border px-3 text-sm font-bold shadow-sm hover:-translate-y-0.5", base, showLabels ? "" : "w-10"]}>
      <svg class="h-4 w-4" viewBox="0 0 24 24" fill={label === "Instagram" ? "none" : "currentColor"} stroke={label === "Instagram" ? "currentColor" : "none"} stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d={path} />
      </svg>
      {showLabels && <span>{label}</span>}
    </a>
  ))}
</div>
