---
interface Props {
  variant?: "light" | "dark";
}

const { variant = "dark" } = Astro.props;
const textClass = variant === "light" ? "text-white" : "text-[var(--text)]";
---

<a href="#top" class={`inline-flex items-center gap-3 ${textClass}`} aria-label="ComputerForms inicio">
  <span class="brand-slot grid h-12 w-48 place-items-center rounded-xl border border-dashed border-[var(--line)] bg-white/70 px-3 text-xs font-bold text-[var(--muted)]">
    <img class="hidden h-9 max-w-full object-contain" src="/brand/logo.svg" alt="ComputerForms" onload="this.classList.remove('hidden'); this.parentElement.dataset.loaded = 'true'" />
    <span class="brand-placeholder">Subir logo.svg</span>
  </span>
</a>
