---
import SocialLinks from "./SocialLinks.astro";
import SplitText from "./reactbits/SplitText";

const contact = [
  ["Telefono", "+52 (33) 1810 3312", "tel:+523318103312"],
  ["WhatsApp", "+52 (33) 1810 3312", "https://wa.me/523318103312?text=Hola%20ComputerForms%2C%20quiero%20informacion%20sobre%20sus%20soluciones."],
  ["Correo", "Escríbenos desde el formulario de contacto", "#contacto"],
  ["Direccion", "Carretera a El Castillo Km 9, Corredor Industrial El Salto, Corredor Industrial, 45680 El Salto, Jal.", "https://www.google.com/maps/place/ComputerForms/@20.5243252,-103.2464191,17z"],
  ["Horario", "Lunes a viernes, 8:00 a 18:30", null],
];

const mapSrc = "https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3736.55830892451!2d-103.2464191!3d20.5243252!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x842f4cbb1ab4a183%3A0xa647a5af45388c69!2sComputerForms!5e0!3m2!1ses-419!2smx!4v1782411771279!5m2!1ses-419!2smx";
const mapTitle = "Ubicacion de ComputerForms en Google Maps";

const getEventName = (href: string | null | undefined): string | undefined => {
  if (!href) return undefined;
  if (href.startsWith("https://wa.me") || href.includes("whatsapp")) return "whatsapp_click";
  if (href.startsWith("tel:")) return "phone_click";
  if (href.startsWith("mailto:")) return "email_click";
  return undefined;
};

const whatsappUrl = "https://wa.me/523318103312?text=Hola%20ComputerForms%2C%20quiero%20cotizar%20un%20proyecto.";
---

<section id="contacto" class="bg-white px-5 py-16 sm:px-8 lg:px-10" aria-labelledby="contacto-title">
  <div class="mx-auto grid max-w-7xl gap-5 lg:grid-cols-[1.15fr_0.85fr] lg:items-stretch">
    <div class="motion-rise rounded-lg border border-cf-navy/10 bg-[linear-gradient(160deg,#002A45_0%,#073a5c_100%)] p-5 text-white shadow-[0_24px_70px_rgb(0_42_69_/_0.14)] sm:p-7">
      <p class="text-sm font-bold uppercase tracking-[0.18em] text-cf-yellow">Contacto</p>
      <h2 id="contacto-title" class="mt-3 font-display text-3xl font-bold text-white sm:text-5xl">
        <SplitText
          client:visible
          text="Cotiza tu proyecto."
          delay={35}
          duration={0.8}
          splitType="words"
          from={{ opacity: 0, y: 28 }}
          to={{ opacity: 1, y: 0 }}
          threshold={0.1}
          rootMargin="-80px"
        />
      </h2>
      <p class="mt-5 text-base leading-7 text-white/76">
        Cuéntanos más sobre tu producto. Te ayudamos a definir alcance, materiales, tiempos de producción y el siguiente paso.
      </p>

      <dl class="mt-8 divide-y divide-white/14 border-y border-white/14">
        {contact.map(([label, value, href]) => (
          <div class="grid gap-1 py-4 sm:grid-cols-[8rem_1fr] sm:gap-6">
            <dt class="text-sm font-semibold text-white/62">{label}</dt>
            <dd class="text-sm font-semibold leading-6 text-white">
              {href ? <a class="hover:text-cf-yellow" href={href} aria-label={`${label}: ${value}`} data-umami-event={getEventName(href)}>{value}</a> : value}
            </dd>
          </div>
        ))}
      </dl>

      <div class="mt-8">
        <SocialLinks tone="dark" showLabels />
      </div>
    </div>

    <div class="motion-rise relative flex h-full flex-col justify-center overflow-hidden rounded-lg border border-cf-navy/10 bg-[#f7fbfd] p-5 shadow-[0_24px_70px_rgb(0_42_69_/_0.09)] sm:p-7">
      <div class="mb-7 overflow-hidden rounded-lg border border-cf-navy/10 bg-white shadow-[0_18px_40px_rgb(0_42_69_/_0.07)]">
        <div class="overflow-hidden">
          <iframe
            class="h-80 w-full sm:w-[calc(100%_+_30px)] sm:-mx-[15px] border-0"
            src={mapSrc}
            aria-label={mapTitle}
            loading="lazy"
            referrerpolicy="strict-origin-when-cross-origin"
            allowfullscreen=""
          ></iframe>
        </div>
      </div>

      <div class="relative z-10 max-w-xl pr-0 sm:pr-44">
        <p class="text-sm font-bold uppercase tracking-[0.18em] text-cf-red">Atención directa</p>
        <h3 class="mt-3 font-display text-3xl font-bold text-[var(--text)] sm:text-4xl">
          Cotiza por WhatsApp.
        </h3>
        <p class="mt-4 text-base leading-7 text-[var(--muted)]">
          Comparte especificaciones, medidas, archivos o referencias. Te orientamos por el mismo canal para avanzar tu proyecto.
        </p>
        <a href={whatsappUrl} target="_blank" rel="noreferrer" data-umami-event="whatsapp_click" class="mt-7 inline-flex w-full justify-center rounded-md bg-[#25D366] px-7 py-3 font-bold text-cf-navy shadow-[0_18px_45px_rgb(37_211_102_/_0.2)] hover:-translate-y-0.5 hover:bg-[#1fc45d] focus:outline-none focus:ring-4 focus:ring-[#25D366]/30 sm:w-auto">
          Abrir WhatsApp
        </a>
      </div>
      <img class="pointer-events-none relative z-0 mx-auto mt-6 h-52 w-full object-contain object-bottom drop-shadow-[0_18px_32px_rgb(0_42_69_/_0.16)] sm:absolute sm:bottom-0 sm:right-4 sm:mt-0 sm:h-64 sm:w-60" src="/brand/jimmy.svg" alt="Jimmy, personaje de ComputerForms" loading="lazy" />
    </div>
  </div>
</section>
