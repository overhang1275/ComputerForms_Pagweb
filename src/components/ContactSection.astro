---
import SocialLinks from "./SocialLinks.astro";

const contact = [
  ["Telefono", "+52 (33) 1810 3312", "tel:+523318103312"],
  ["WhatsApp", "+52 (33) 1810 3312", "https://wa.me/523318103312?text=Hola%20ComputerForms%2C%20quiero%20informacion%20sobre%20sus%20soluciones."],
  ["Correo", "hola@computerforms.com.mx", "mailto:hola@computerforms.com.mx"],
  ["Direccion", "Carretera a El Castillo Km 9, Corredor Industrial El Salto, Corredor Industrial, 45680 El Salto, Jal.", null],
  ["Horario", "Lunes a viernes, 8:00 a 18:30", null],
];

const whatsappUrl = "https://wa.me/523318103312?text=Hola%20ComputerForms%2C%20quiero%20cotizar%20un%20proyecto.";
---

<section id="contacto" class="bg-white px-5 py-16 sm:px-8 lg:px-10" aria-labelledby="contacto-title">
  <div class="mx-auto grid max-w-7xl gap-8 lg:grid-cols-[1.15fr_0.85fr]">
    <div class="motion-rise rounded-[2rem] border border-cf-navy/10 bg-[linear-gradient(160deg,#002A45_0%,#073a5c_100%)] p-6 text-white shadow-[0_24px_80px_rgb(0_42_69_/_0.16)] sm:p-8">
      <p class="text-sm font-bold uppercase tracking-[0.18em] text-cf-yellow">Contacto</p>
      <h2 id="contacto-title" class="mt-3 font-display text-3xl font-bold text-white sm:text-5xl">
        Cotiza impresion, rotulacion o etiquetas.
      </h2>
      <p class="mt-5 text-base leading-7 text-white/76">
        Cuentanos que producto necesitas fabricar, imprimir o instalar. Te orientamos sobre alcance, materiales, tiempos y siguiente paso.
      </p>

      <dl class="mt-8 grid gap-4">
        {contact.map(([label, value, href]) => (
          <div class="rounded-2xl border border-white/15 bg-white/8 p-4">
            <dt class="text-sm font-semibold text-white/62">{label}</dt>
            <dd class="mt-1 font-semibold text-white">
              {href ? <a class="hover:text-cf-yellow" href={href}>{value}</a> : value}
            </dd>
          </div>
        ))}
      </dl>

      <div class="mt-8">
        <SocialLinks tone="dark" showLabels />
      </div>
    </div>

    <div class="motion-rise relative self-start overflow-hidden rounded-[2rem] border border-cf-navy/10 bg-[#f7fbfd] p-6 shadow-[0_24px_80px_rgb(0_42_69_/_0.1)] sm:p-8">
      <div class="relative z-10 max-w-xl pr-0 sm:pr-44">
        <p class="text-sm font-bold uppercase tracking-[0.18em] text-cf-red">Atencion directa</p>
        <h3 class="mt-3 font-display text-3xl font-bold text-[var(--text)] sm:text-4xl">
          WhatsApp para revisar tu requerimiento.
        </h3>
        <p class="mt-4 text-base leading-7 text-[var(--muted)]">
          Envia especificaciones, medidas, archivos o fotos de referencia. Respondemos por el mismo canal para avanzar la cotizacion.
        </p>
        <a href={whatsappUrl} target="_blank" rel="noreferrer" class="mt-7 inline-flex w-full justify-center rounded-full bg-[#25D366] px-7 py-3 font-bold text-cf-navy shadow-[0_18px_45px_rgb(37_211_102_/_0.24)] hover:-translate-y-0.5 hover:bg-[#1fc45d] focus:outline-none focus:ring-4 focus:ring-[#25D366]/30 sm:w-auto">
          Abrir WhatsApp
        </a>
      </div>
      <img class="pointer-events-none relative z-0 mx-auto mt-6 h-52 w-full object-contain object-bottom drop-shadow-[0_18px_32px_rgb(0_42_69_/_0.16)] sm:absolute sm:bottom-0 sm:right-4 sm:mt-0 sm:h-64 sm:w-60" src="/brand/jimmy.svg" alt="Jimmy, personaje de ComputerForms" loading="lazy" />
    </div>
  </div>
</section>
