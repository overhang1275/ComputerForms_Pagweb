---
import Logo from "./Logo.astro";
const year = new Date().getFullYear();
---

<footer class="px-5 pb-8 pt-10 sm:px-8 lg:px-10">
  <div class="mx-auto flex max-w-7xl flex-col gap-6 border-t border-[var(--line)] pt-8 sm:flex-row sm:items-center sm:justify-between">
    <div>
      <Logo />
      <img class="mt-5 h-auto w-64 max-w-full opacity-90" src="/brand/printing-your-dreams.svg" alt="Printing your dreams" />
      <p class="mt-3 max-w-md text-sm leading-6 text-[var(--muted)]">
        Impresion especializada, comunicacion visual, branding, desarrollo digital y empaques.
      </p>
    </div>
    <div class="text-sm leading-6 text-[var(--muted)] sm:text-right">
      <p>(c) {year} ComputerForms. Derechos reservados.</p>
      <p><a class="font-semibold text-[var(--text)] hover:text-cf-red" href="mailto:hola@computerforms.com.mx">hola@computerforms.com.mx</a></p>
    </div>
  </div>
</footer>
