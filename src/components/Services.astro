---
const services = [
  ["Formas", "Documentos, controles e impresion de seguridad para operacion critica.", "M5 11h38v26H5z M15 18h18 M15 26h18 M15 34h12"],
  ["Gran Formato", "Comunicacion visual de alto impacto para espacios comerciales e institucionales.", "M5 10h38v24H5z M12 38h24 M17 18l6 7 5-4 8 9"],
  ["Etiquetas", "Identificacion, trazabilidad y acabados de marca para productos.", "M8 12h18l14 14-14 14L8 22z M18 21h.1"],
];
---

<section class="relative overflow-hidden bg-[linear-gradient(180deg,rgba(238,246,251,0.9)_0%,rgba(249,252,253,0.94)_100%)] px-5 py-16 sm:px-8 lg:px-10" aria-labelledby="servicios-title">
  <div class="mx-auto max-w-7xl">
    <div class="max-w-3xl">
      <p class="text-sm font-bold uppercase tracking-[0.18em] text-cf-red">Servicios destacados</p>
      <h2 id="servicios-title" class="mt-3 font-display text-3xl font-bold text-[var(--text)] sm:text-5xl">
        Soluciones listas para empresas que no pueden verse improvisadas.
      </h2>
    </div>
    <div class="mt-10 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {services.map(([name, text, path]) => (
        <article class="motion-rise group rounded-2xl border border-cf-navy/10 bg-white p-5 shadow-sm hover:-translate-y-1 hover:shadow-premium">
          <svg class="mb-5 h-10 w-10 text-cf-navy group-hover:text-cf-red" viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d={path} />
          </svg>
          <h3 class="font-display text-xl font-bold text-[var(--text)]">{name}</h3>
          <p class="mt-3 text-sm leading-6 text-[var(--muted)]">{text}</p>
        </article>
      ))}
    </div>
  </div>
</section>
