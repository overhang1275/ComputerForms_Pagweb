---
const services = [
  {
    name: "Formas",
    text: "Conceptualizacion, diseno, fabricacion e impresion de documentos oficiales, formas valoradas y productos de seguridad.",
    path: "M5 11h38v26H5z M15 18h18 M15 26h18 M15 34h12",
    items: ["Formas valoradas, comerciales, laser y continuas", "Titulos, actas, certificados escolares y vehiculares", "Hologramas, placas, boletas electorales y cedulas", "Credenciales, identificaciones y boletos de acceso", "Libros, revistas, braille, correo directo y formatos inteligentes"],
  },
  {
    name: "Gran formato",
    text: "Produccion, instalacion y rotulacion para comunicacion visual en exteriores, interiores, vehiculos y puntos de venta.",
    path: "M5 10h38v24H5z M12 38h24 M17 18l6 7 5-4 8 9",
    items: ["Rotulacion vehicular, exterior e interior", "Stands, mobiliario POP, exhibidores y cajas de luz", "Lonas, carteles, banners, posters y espectaculares", "Letreros canteados, luminosos y reconocimientos", "Decoracion, interiorismo, senaletica y cuadros canvas"],
  },
  {
    name: "Etiquetas / Mangas",
    text: "Desarrollo, impresion y acabado de etiquetas, mangas termoencogibles y empaques para producto.",
    path: "M8 12h18l14 14-14 14L8 22z M18 21h.1",
    items: ["Etiquetas inteligentes, autoadheribles y de seguridad", "Etiquetas textiles, RFID, para vinos y licores", "Sellos de evidencia tamper evident", "Mangas termoencogibles para envases", "Cajas de empaque y acabados para anaquel"],
  },
];
---

<section class="relative overflow-hidden bg-[linear-gradient(180deg,rgba(238,246,251,0.9)_0%,rgba(249,252,253,0.94)_100%)] px-5 py-12 sm:px-8 sm:py-16 lg:px-10" aria-labelledby="servicios-title">
  <div class="mx-auto max-w-7xl">
    <div class="max-w-3xl">
      <p class="text-xs font-bold uppercase tracking-[0.18em] text-cf-red sm:text-sm">Lineas de negocio</p>
      <h2 id="servicios-title" class="mt-3 font-display text-2xl font-bold leading-tight text-[var(--text)] sm:text-5xl">
        Produccion impresa especializada para operacion, promocion y empaque.
      </h2>
    </div>
    <div class="mt-8 grid gap-4 sm:mt-10 sm:grid-cols-2 lg:grid-cols-3">
      {services.map(({ name, text, path, items }) => (
        <article class="motion-rise group rounded-2xl border border-cf-navy/10 bg-white p-4 shadow-sm hover:-translate-y-1 hover:shadow-premium sm:p-5">
          <div class="flex items-center gap-3">
            <svg class="h-9 w-9 shrink-0 text-cf-navy group-hover:text-cf-red sm:h-10 sm:w-10" viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d={path} />
            </svg>
            <h3 class="font-display text-xl font-bold text-[var(--text)]">{name}</h3>
          </div>
          <p class="mt-3 text-sm leading-6 text-[var(--muted)]">{text}</p>
          <ul class="mt-5 grid gap-2 text-sm font-semibold leading-5 text-[var(--text)]">
            {items.map((item) => (
              <li class="flex gap-2">
                <span class="mt-2 h-1.5 w-1.5 shrink-0 rounded-full bg-cf-red"></span>
                <span>{item}</span>
              </li>
            ))}
          </ul>
        </article>
      ))}
    </div>
  </div>
</section>
