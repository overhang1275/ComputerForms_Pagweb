---
import Logo from "./Logo.astro";
import SocialLinks from "./SocialLinks.astro";
import GradientText from "./reactbits/GradientText";
import "./reactbits/GradientText.css";

const whatsappUrl = "https://wa.me/523318103312?text=Hola%20ComputerForms%2C%20quiero%20informacion%20sobre%20sus%20soluciones.";
---

<section id="top" class="relative isolate overflow-hidden bg-[linear-gradient(135deg,rgba(255,255,255,0.94)_0%,rgba(255,255,255,0.92)_48%,rgba(238,246,251,0.92)_100%)] px-5 pb-16 pt-6 sm:px-8 lg:px-10">
  <div class="relative z-10 mx-auto flex max-w-7xl items-center justify-between">
    <Logo />
    <div class="hidden items-center gap-3 sm:flex">
      <SocialLinks />
      <a href="#contacto" class="rounded-full border border-cf-navy/15 bg-white px-4 py-2 text-sm font-semibold text-[var(--text)] shadow-sm hover:-translate-y-0.5 hover:border-cf-yellow">
        Contacto
      </a>
    </div>
  </div>

  <div class="relative z-10 mx-auto grid max-w-7xl items-center gap-12 py-16 sm:py-20 lg:grid-cols-[1.04fr_0.96fr] lg:py-24">
    <div class="motion-rise">
      <img class="motion-rise mb-6 h-auto w-72 max-w-full" src="/brand/printing-your-dreams.svg" alt="Printing your dreams" />
      <h1 class="motion-rise max-w-4xl font-display text-5xl font-bold leading-[0.96] tracking-normal text-[var(--text)] sm:text-6xl lg:text-7xl">
        <GradientText client:load colors={["#002A45", "#0B5F8A", "#167DA8", "#002A45"]} animationSpeed={8} showBorder={false}>
          Impresion de seguridad, gran formato y etiquetas para empresas.
        </GradientText>
      </h1>
      <p class="motion-rise mt-6 max-w-2xl text-lg leading-8 text-[var(--muted)] sm:text-xl">
        Fabricamos formas valoradas, documentos oficiales, rotulacion, publicidad exterior, etiquetas, mangas termoencogibles y empaques desde Jalisco para proyectos en Mexico.
      </p>
      <div class="motion-rise mt-9 flex flex-col gap-3 sm:flex-row">
        <a href="#contacto" class="inline-flex items-center justify-center rounded-full bg-cf-navy px-6 py-3 text-base font-bold text-white shadow-premium hover:-translate-y-0.5 hover:bg-[#073a5c] focus:outline-none focus:ring-4 focus:ring-cf-yellow/40">
          Cotizar proyecto
        </a>
        <a href={whatsappUrl} target="_blank" rel="noreferrer" data-umami-event="whatsapp_click" class="inline-flex items-center justify-center rounded-full border border-cf-navy/15 bg-white px-6 py-3 text-base font-bold text-[var(--text)] shadow-sm hover:-translate-y-0.5 hover:border-[#25D366]">
          WhatsApp
        </a>
      </div>
    </div>

    <div class="motion-float relative min-h-[420px]">
      <div class="absolute inset-10 rounded-full bg-cf-navy/5 blur-3xl"></div>
      <div class="absolute inset-6 rounded-[3rem] bg-[radial-gradient(circle,#ffffff_0%,rgba(238,246,251,0.72)_62%,transparent_72%)]"></div>
      <div class="absolute left-1/2 top-1/2 h-[min(82vw,28rem)] w-[min(82vw,28rem)] -translate-x-1/2 -translate-y-1/2">
        <img class="spin-figure h-full w-full object-contain drop-shadow-[0_24px_45px_rgb(0_42_69_/_0.16)]" src="/brand/spin.svg" alt="" aria-hidden="true" />
      </div>
    </div>
  </div>
</section>
